generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model DailySummary {
  id          String   @id @default(cuid())
  date        DateTime @unique
  pdfUrl      String
  rawText     String
  summary     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
