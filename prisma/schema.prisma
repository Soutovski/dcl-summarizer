generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailySummary {
  id          String   @id @default(cuid())
  date        DateTime @unique
  pdfUrl      String
  rawText     String
  summary     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
